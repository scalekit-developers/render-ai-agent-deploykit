OPENAI_API_KEY=your-openai-api-key

# LiteLLM proxy (optional — if set, takes precedence over OPENAI_API_KEY)
LITELLM_API_KEY=
LITELLM_BASE_URL=https://llm.scalekit.cloud
LITELLM_MODEL=claude-sonnet-4-6

RENDER_API_KEY=your-render-api-key
RENDER_WORKFLOW_SLUG=docfix

# Linear webhook (from Linear workspace settings → Webhooks)
LINEAR_WEBHOOK_SECRET=your-linear-webhook-secret
# Linear service API key — used for bot comments (no user OAuth required)
# Get from: Linear → Settings → API → Personal API keys
LINEAR_API_KEY=your-linear-api-key

# Scalekit Agent Auth
SCALEKIT_ENVIRONMENT_URL=https://your-env.scalekit.com
SCALEKIT_CLIENT_ID=your-scalekit-client-id
SCALEKIT_CLIENT_SECRET=your-scalekit-client-secret

# Auth setup service
AUTH_BASE_URL=http://localhost:3002
WEBHOOK_PORT=3001
AUTH_PORT=3002
