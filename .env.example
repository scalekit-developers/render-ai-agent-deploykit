# Web server
PORT=3000

# Public URL of this service — used to build the OAuth callback URL (/user/verify).
# In development: http://localhost:3000
# In production:  https://your-service.onrender.com
PUBLIC_BASE_URL=http://localhost:3000

# Session secret — signs HTTP-only session cookies (HMAC-SHA256).
# Generate with: openssl rand -hex 32
SESSION_SECRET=your-session-secret

# LLM — any OpenAI-compatible API. Leave OPENAI_BASE_URL empty to use OpenAI directly;
# set it to a proxy URL to route calls through LiteLLM, Azure OpenAI, Ollama, etc.
#
# OpenAI direct:
#   OPENAI_API_KEY=sk-...
#   OPENAI_BASE_URL=          (leave empty)
#   OPENAI_MODEL=gpt-4.1-mini
#
# LiteLLM proxy:
#   OPENAI_API_KEY=<your-litellm-proxy-token>
#   OPENAI_BASE_URL=https://your-litellm-proxy.example.com
#   OPENAI_MODEL=claude-haiku-4-5   (or any model your proxy serves)
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini

# Scalekit AgentKit
SCALEKIT_ENVIRONMENT_URL=https://your-env.scalekit.com
SCALEKIT_CLIENT_ID=your-scalekit-client-id
SCALEKIT_CLIENT_SECRET=your-scalekit-client-secret

# Scalekit GitHub connection name — copy from Scalekit Dashboard → AgentKit → Connectors
# Each Scalekit environment gets a unique name (e.g. github-abc12345). Required.
GITHUB_CONNECTION_NAME=your-github-connection-name
