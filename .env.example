# Web server
PORT=3000

# Public URL of this service — used to build the OAuth callback URL (/user/verify).
# In development: http://localhost:3000
# In production:  https://your-service.onrender.com
PUBLIC_BASE_URL=http://localhost:3000

# Session secret — signs HTTP-only session cookies (HMAC-SHA256).
# Generate with: openssl rand -hex 32
SESSION_SECRET=your-session-secret

# LLM — any OpenAI-compatible API (LiteLLM, OpenAI, Azure OpenAI, Ollama, etc.)
# Omit LITELLM_BASE_URL to call OpenAI directly.
LITELLM_API_KEY=your-api-key
LITELLM_BASE_URL=https://your-litellm-base-url
LITELLM_MODEL=claude-haiku-4-5

# Scalekit Agent Auth
SCALEKIT_ENVIRONMENT_URL=https://your-env.scalekit.com
SCALEKIT_CLIENT_ID=your-scalekit-client-id
SCALEKIT_CLIENT_SECRET=your-scalekit-client-secret

# Scalekit GitHub connection name — copy from Scalekit Dashboard → Agent Auth → Connectors
# Each Scalekit environment gets a unique name (e.g. github-abc12345). Required.
GITHUB_CONNECTION_NAME=your-github-connection-name
